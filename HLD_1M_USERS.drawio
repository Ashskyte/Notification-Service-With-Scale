        <mxCell id="DP" value="&lt;font style=&quot;font-size:11px;&quot;&gt;&lt;b&gt;Design Patterns Used:&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;&quot;&gt;✓ Publish-Subscribe (Kafka)&lt;br&gt;✓ Event-Driven Architecture&lt;br&gt;✓ Competing Consumers&lt;br&gt;✓ Dead Letter Queue&lt;br&gt;✓ CQRS (Read Replicas)&lt;br&gt;✓ Circuit Breaker (Resilience4j)&lt;br&gt;✓ Cache-Aside (Redis)&lt;br&gt;✓ Distributed Lock (ShedLock)&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#82b366;shadow=1;align=left;spacingLeft=10;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
