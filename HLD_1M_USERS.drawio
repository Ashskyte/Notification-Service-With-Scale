        <mxCell id="M4" value="&lt;b&gt;Jaeger / Zipkin&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Distributed tracing&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d0e6f0;strokeColor=#56a5c4;shadow=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="830" y="1300" width="160" height="55" as="geometry"/>
